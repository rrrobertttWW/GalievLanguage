<Page x:Class="GalievLanguageSchool.AddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="500"
      Title="Клиент" FontFamily="Comic Sans MS">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ID (только для редактирования) -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <TextBox Name="TbID" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="LightGray" Margin="5" Visibility="Collapsed"/>

        <!-- Фамилия -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <TextBox Name="TbFirstName" Grid.Row="1" Grid.Column="1" Margin="5" MaxLength="50"/>

        <!-- Имя -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <TextBox Name="TbLastName" Grid.Row="2" Grid.Column="1" Margin="5" MaxLength="50"/>

        <!-- Отчество -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <TextBox Name="TbMiddleName" Grid.Row="3" Grid.Column="1" Margin="5" MaxLength="50"/>

        <!-- Email -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Email:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <TextBox Name="TbEmail" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <TextBox Name="TbPhone" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <!-- Дата рождения -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <DatePicker Name="DpBirthday" Grid.Row="6" Grid.Column="1" Margin="5"/>

        <!-- Пол -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Пол:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <RadioButton Name="RbMale" Content="Мужской" GroupName="Gender" Margin="5"/>
            <RadioButton Name="RbFemale" Content="Женский" GroupName="Gender" Margin="5"/>
        </StackPanel>

        <!-- Фотография -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Фотография:" VerticalAlignment="Center" FontSize="16" Margin="5"/>
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <Button Name="BtnSelectPhoto" Content="Выбрать фото" Click="BtnSelectPhoto_Click" Margin="5"/>
            <Image Name="ImgPhoto" Width="80" Height="80" Stretch="UniformToFill" Margin="5"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Name="BtnSave" Content="Сохранить" Click="BtnSave_Click" Width="100" Height="35" Margin="10"/>
            <Button Name="BtnCancel" Content="Отмена" Click="BtnCancel_Click" Width="100" Height="35" Margin="10"/>
        </StackPanel>
    </Grid>
</Page>